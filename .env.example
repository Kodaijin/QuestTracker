DATABASE_URL=postgresql://questlog_user:questlog_password@db:5432/questlog_dev
POSTGRES_USER=questlog_user
POSTGRES_PASSWORD=questlog_password
POSTGRES_DB=questlog_dev
NEXTAUTH_SECRET=your-super-secret-key-change-this-in-production
# Public base URL of the app. In production behind a proxy/tunnel set this to
# your real domain (e.g. https://quests.example.com), NOT localhost — it drives
# auth redirects and is trusted for Server Actions.
NEXTAUTH_URL=http://localhost:3000

# Comma-separated public origin(s) allowed to invoke Server Actions (mutations).
# REQUIRED when running behind a reverse proxy / Cloudflare Tunnel, otherwise the
# forwarded Host won't match the browser Origin and every mutation returns a 500.
# Use the host only, no protocol. Example: quests.example.com,www.example.com
# (NEXTAUTH_URL's host is trusted automatically; set this for extra origins.)
ALLOWED_ORIGINS=

# Local timezone for quest reset / missed-quest day boundaries (midnight).
# Etc/GMT+8 = UTC-8 fixed (no DST). For DST-aware Pacific use America/Los_Angeles.
TZ=Etc/GMT+8

# Web Push (VAPID) — required for push reminders. Generate a pair with:
#   npx web-push generate-vapid-keys --json
# The public key is served to the browser at runtime (no NEXT_PUBLIC_ build step needed).
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:you@example.com

# How often the in-process reminder scheduler runs, in minutes. Set 0 to disable.
REMINDER_SWEEP_MINUTES=15

# Native push (FCM), optional. Only needed for the Capacitor Android app. Paste a
# Firebase service-account JSON (single line) that has Cloud Messaging access.
# Leave empty to disable native push; Web Push still works without it.
FCM_SERVICE_ACCOUNT_JSON=

# Discord integration, optional. A single channel webhook URL (Discord → Server
# Settings → Integrations → Webhooks → New Webhook → Copy Webhook URL). When set,
# the app posts rich-embed messages for daily reminders, new group-quest invites,
# party progress updates, deadline alerts and group-quest completions to that
# channel, @mentioning users who added a Discord handle in their settings. Leave
# empty to disable the integration entirely.
DISCORD_WEBHOOK_URL=

# ── Discord bot (optional) ───────────────────────────────────────────────────
# Runs the `bot` service (see bot/) to add /addquest and /quests slash commands.
# All four below are required for the bot; leave them empty to skip the bot.
#
# Create an application + bot at https://discord.com/developers/applications:
#   DISCORD_BOT_TOKEN  – Bot → Reset Token → copy.
#   DISCORD_APP_ID     – General Information → Application ID.
#   DISCORD_GUILD_ID   – your server's ID (enable Developer Mode → right-click
#                        server → Copy Server ID). Optional: when set, slash
#                        commands register instantly to that one server.
# The bot maps a Discord user to a QuestTracker account via the numeric Discord ID
# saved under Settings → Discord, so users must set that to use the commands.
DISCORD_BOT_TOKEN=
DISCORD_APP_ID=
DISCORD_GUILD_ID=

# Shared secret authenticating the bot to the app's /api/bot/quests endpoint. Use
# a long random string (e.g. `openssl rand -hex 32`). Must match in both services.
BOT_API_SECRET=

# Override only if the bot can't reach the app at the compose default. In Docker
# Compose the bot reaches the app at http://app:3000 automatically.
# BOT_APP_URL=http://app:3000
