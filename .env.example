DATABASE_URL=postgresql://questlog_user:questlog_password@db:5432/questlog_dev
POSTGRES_USER=questlog_user
POSTGRES_PASSWORD=questlog_password
POSTGRES_DB=questlog_dev
NEXTAUTH_SECRET=your-super-secret-key-change-this-in-production
NEXTAUTH_URL=http://localhost:3000

# Local timezone for quest reset / missed-quest day boundaries (midnight).
# Etc/GMT+8 = UTC-8 fixed (no DST). For DST-aware Pacific use America/Los_Angeles.
TZ=Etc/GMT+8

# Web Push (VAPID) — required for push reminders. Generate a pair with:
#   npx web-push generate-vapid-keys --json
# The public key is served to the browser at runtime (no NEXT_PUBLIC_ build step needed).
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:you@example.com

# How often the in-process reminder scheduler runs, in minutes. Set 0 to disable.
REMINDER_SWEEP_MINUTES=15
