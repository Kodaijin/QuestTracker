datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

enum RecurrenceType {
  NONE
  DAILY
  WEEKLY
  EVERY_N_WEEKS
  MONTHLY
  SPECIFIC_DATE
}

enum Difficulty {
  TRIVIAL
  EASY
  NORMAL
  HARD
  LEGENDARY
}

enum CompletionType {
  OBJECTIVE
  QUEST
  ITEM
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model User {
  id                   String                 @id @default(cuid())
  email                String                 @unique
  username             String?                @unique
  passwordHash         String
  name                 String?
  createdAt            DateTime               @default(now())
  securityQuestion     String?
  securityAnswerHash   String?
  // Optional Discord handle for the shared-channel webhook integration. An
  // all-digit value is treated as a numeric User ID (real @mention/ping); any
  // other value renders as plain @name text. Blank = opted out. See src/lib/discord.ts.
  discordUsername      String?
  // Equipped cosmetic ids (null = default look). See src/lib/cosmetics.ts.
  themeId              String?
  xpBarId              String?
  frameId              String?
  particleId           String?
  backgroundId         String?
  // When true, all cosmetics are unlocked & equippable without spending gems.
  cosmeticsFree        Boolean                @default(false)
  projects             Project[]
  achievements         UnlockedAchievement[]
  completionEvents     CompletionEvent[]
  sentRequests         Connection[]           @relation("Requester")
  receivedRequests     Connection[]           @relation("Addressee")
  questMemberships     QuestMember[]
  pet                  Pet?
  pushSubscriptions    PushSubscription[]
  deviceTokens         DeviceToken[]
  notifications        Notification[]
  notificationPreference NotificationPreference?
  cosmetics            CosmeticUnlock[]
}

// A cosmetic the user has purchased with Quest Gems. Ownership only; the gem
// balance is derived (earned − sum of owned prices), see src/lib/cosmetics.ts.
model CosmeticUnlock {
  id         String   @id @default(cuid())
  userId     String
  cosmeticId String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, cosmeticId])
  @@index([userId])
}

// A personal companion that evolves with the hero's level and reacts to streaks.
// Only identity is stored; stage/mood are derived at read time (see src/lib/pet.ts).
model Pet {
  id        String   @id @default(cuid())
  userId    String   @unique
  name      String
  species   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// A Web Push subscription endpoint registered by a user's browser.
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// A native push (FCM) device token registered by the Capacitor Android app.
// The web uses PushSubscription (Web Push); the app uses these.
model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String   @default("android")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// In-app notification history; also the source of truth for push dedupe.
model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  href      String?
  dedupeKey String
  readAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, dedupeKey])
  @@index([userId, createdAt])
}

// Per-user reminder preferences.
model NotificationPreference {
  userId       String  @id
  enabled      Boolean @default(true)
  inactivity   Boolean @default(true)
  streak       Boolean @default(true)
  deadline     Boolean @default(true)
  pet          Boolean @default(true)
  reminderHour Int     @default(18)
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Persistent hero-to-hero connection (friend link). One row per ordered pair.
model Connection {
  id          String       @id @default(cuid())
  requesterId String
  addresseeId String
  status      InviteStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  requester   User         @relation("Requester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee   User         @relation("Addressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([addresseeId])
}

// Per-quest membership / invite. The owner remains Project.userId; this tracks
// the other heroes a quest is shared with and whether they've accepted.
model QuestMember {
  id        String       @id @default(cuid())
  projectId String
  userId    String
  status    InviteStatus @default(PENDING)
  createdAt DateTime     @default(now())
  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
}

model Project {
  id              String         @id @default(cuid())
  title           String
  description     String?
  userId          String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  recurrenceType  RecurrenceType @default(NONE)
  dayOfWeek       Int?
  intervalWeeks   Int?
  dayOfMonth      Int?
  specificDate    DateTime?
  dueDate         DateTime?
  lastCompletedAt DateTime?
  availableAt     DateTime?
  deadline        DateTime?
  icon            String?
  difficulty      Difficulty     @default(NORMAL)
  tags            String[]       @default([])
  isEpic          Boolean        @default(false)
  sequential      Boolean        @default(false)
  // For standalone/sub-quests: whether objectives must be checked off in order
  // (later objectives stay locked 🔒 until earlier ones are complete). The epic-
  // level analogue for sub-quests is `sequential`.
  sequentialObjectives Boolean   @default(false)
  // Manual ordering for the dashboard board (lower = earlier). Only meaningful for
  // top-level quests; sub-quests order within their epic via `epicOrder`.
  sortOrder       Int            @default(0)
  // For shared (party) quests: whether accepted members may edit the quest
  // (add/edit objectives & inventory, change settings). Deleting stays owner-only.
  membersCanEdit  Boolean        @default(true)
  parentId        String?
  epicOrder       Int?
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent          Project?       @relation("EpicChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children        Project[]      @relation("EpicChildren")
  objectives      Objective[]
  inventoryItems  InventoryItem[]
  members         QuestMember[]

  @@index([userId])
  @@index([parentId])
}

model Objective {
  id          String  @id @default(cuid())
  title       String
  isCompleted Boolean @default(false)
  order       Int
  projectId   String
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model InventoryItem {
  id        String  @id @default(cuid())
  name      String
  gathered  Boolean @default(false)
  order     Int     @default(0)
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model CompletionEvent {
  id        String         @id @default(cuid())
  userId    String
  type      CompletionType
  projectId String?
  xp        Int
  createdAt DateTime       @default(now())
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model UnlockedAchievement {
  id         String   @id @default(cuid())
  key        String
  unlockedAt DateTime @default(now())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId])
}
