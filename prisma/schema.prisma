datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

enum RecurrenceType {
  NONE
  DAILY
  WEEKLY
  EVERY_N_WEEKS
  MONTHLY
  SPECIFIC_DATE
}

enum Difficulty {
  TRIVIAL
  EASY
  NORMAL
  HARD
  LEGENDARY
}

enum CompletionType {
  OBJECTIVE
  QUEST
  ITEM
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model User {
  id                   String                 @id @default(cuid())
  email                String                 @unique
  username             String?                @unique
  passwordHash         String
  name                 String?
  createdAt            DateTime               @default(now())
  securityQuestion     String?
  securityAnswerHash   String?
  projects             Project[]
  achievements         UnlockedAchievement[]
  completionEvents     CompletionEvent[]
  sentRequests         Connection[]           @relation("Requester")
  receivedRequests     Connection[]           @relation("Addressee")
  questMemberships     QuestMember[]
}

// Persistent hero-to-hero connection (friend link). One row per ordered pair.
model Connection {
  id          String       @id @default(cuid())
  requesterId String
  addresseeId String
  status      InviteStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  requester   User         @relation("Requester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee   User         @relation("Addressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([addresseeId])
}

// Per-quest membership / invite. The owner remains Project.userId; this tracks
// the other heroes a quest is shared with and whether they've accepted.
model QuestMember {
  id        String       @id @default(cuid())
  projectId String
  userId    String
  status    InviteStatus @default(PENDING)
  createdAt DateTime     @default(now())
  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
}

model Project {
  id              String         @id @default(cuid())
  title           String
  description     String?
  userId          String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  recurrenceType  RecurrenceType @default(NONE)
  dayOfWeek       Int?
  intervalWeeks   Int?
  dayOfMonth      Int?
  specificDate    DateTime?
  dueDate         DateTime?
  lastCompletedAt DateTime?
  availableAt     DateTime?
  deadline        DateTime?
  icon            String?
  difficulty      Difficulty     @default(NORMAL)
  tags            String[]       @default([])
  isEpic          Boolean        @default(false)
  sequential      Boolean        @default(false)
  parentId        String?
  epicOrder       Int?
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent          Project?       @relation("EpicChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children        Project[]      @relation("EpicChildren")
  objectives      Objective[]
  inventoryItems  InventoryItem[]
  members         QuestMember[]

  @@index([userId])
  @@index([parentId])
}

model Objective {
  id          String  @id @default(cuid())
  title       String
  isCompleted Boolean @default(false)
  order       Int
  projectId   String
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model InventoryItem {
  id        String  @id @default(cuid())
  name      String
  gathered  Boolean @default(false)
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model CompletionEvent {
  id        String         @id @default(cuid())
  userId    String
  type      CompletionType
  projectId String?
  xp        Int
  createdAt DateTime       @default(now())
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model UnlockedAchievement {
  id         String   @id @default(cuid())
  key        String
  unlockedAt DateTime @default(now())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId])
}
